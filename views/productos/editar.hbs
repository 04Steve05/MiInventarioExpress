<div class="formulario-contenedor">
  <h2>Editar Producto</h2>
  {{#if errores}}
    <ul class="errores">
      {{#each errores}}
        <li>{{msg}}</li>
      {{/each}}
    </ul>
  {{/if}}
  <form action="/productos/editar/{{producto._id}}" method="POST" enctype="multipart/form-data">
    <div class="campo">
      <label for="nombre">Nombre</label>
      <input type="text" id="nombre" name="nombre" value="{{producto.nombre}}" required>
    </div>
    <div class="campo">
      <label for="precio">Precio</label>
      <input type="number" id="precio" name="precio" value="{{producto.precio}}" step="0.01" required>
    </div>
    <div class="campo">
      <label for="descripcion">Descripción</label>
      <textarea id="descripcion" name="descripcion" rows="4" required>{{producto.descripcion}}</textarea>
    </div>
    <div class="campo">
      <label for="imagen">Cambiar imagen (opcional)</label>
      <input type="file" id="imagen" name="imagen" accept="image/jpeg,image/png">
      {{#if producto.imagen}}
        <img src="{{rutaImagen producto.imagen}}" alt="Imagen actual" class="imagen-preview">
      {{/if}}
    </div>
    <div class="botones">
      <button type="submit" class="boton-primario">Actualizar</button>
      <a href="/productos" class="boton-secundario">Cancelar</a>
    </div>
  </form>
</div>
