<div class="formulario-contenedor">
  <h2>Nuevo Producto</h2>
  {{#if errores}}
    <ul class="errores">
      {{#each errores}}
        <li>{{msg}}</li>
      {{/each}}
    </ul>
  {{/if}}
  <form action="/productos/crear" method="POST" enctype="multipart/form-data">
    <div class="campo">
      <label for="nombre">Nombre</label>
      <input type="text" id="nombre" name="nombre" required>
    </div>
    <div class="campo">
      <label for="precio">Precio</label>
      <input type="number" id="precio" name="precio" step="0.01" required>
    </div>
    <div class="campo">
      <label for="descripcion">Descripción</label>
      <textarea id="descripcion" name="descripcion" rows="4" required></textarea>
    </div>
    <div class="campo">
      <label for="imagen">Imagen (JPG o PNG, máx 2MB)</label>
      <input type="file" id="imagen" name="imagen" accept="image/jpeg,image/png">
    </div>
    <div class="botones">
      <button type="submit" class="boton-primario">Guardar</button>
      <a href="/productos" class="boton-secundario">Cancelar</a>
    </div>
  </form>
</div>
